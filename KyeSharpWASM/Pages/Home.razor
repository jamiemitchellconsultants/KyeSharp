@page "/"

<PageTitle>KyeSharp</PageTitle>

<style>
    .home-wrap {
        display: flex; flex-direction: column; align-items: center;
        justify-content: center; min-height: 100vh;
        background: #0a0a1a; color: #ddd;
        font-family: 'Courier New', monospace;
    }
    .home-wrap h1 { color: #f0c040; text-shadow: 0 0 14px #f0c040; font-size: 3em; letter-spacing: 0.2em; margin-bottom: 10px; }
    .home-wrap p  { color: #5a7a9a; margin-bottom: 30px; }
    .play-btn {
        padding: 14px 44px; font-size: 1.3em;
        background: #1a3a6a; color: #c8e0ff;
        border: 2px solid #3a6aaa; border-radius: 10px;
        text-decoration: none; font-family: inherit;
        transition: background 0.2s, box-shadow 0.2s;
        box-shadow: 0 0 16px rgba(40,100,220,0.3);
    }
    .play-btn:hover { background: #255090; box-shadow: 0 0 28px rgba(40,120,255,0.5); }

    .home-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        justify-content: center;
    }
</style>

<div class="home-wrap">
    <h1>KYE</h1>
    <p>A classic puzzle game — collect all diamonds to open the exit!</p>
    <div class="home-actions">
        <a class="play-btn" href="/kye">▶ Play Now</a>
        <a class="play-btn" href="/editor">✎ Level Editor</a>
    </div>
</div>
